{
  "name": "finance-pr-qonto",
  "version": "0.1.0",
  "type": "module",
  "description": "Finance PR turns every AI-proposed financial action into a reviewable, evidence-bound change request before it reaches Qonto approval.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "pr": "tsx src/node/cli.ts",
    "scan:secrets": "node scripts/scan-secrets.mjs"
  },
  "dependencies": {
    "js-sha256": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^2.0.5",
    "tsx": "^4.17.0"
  }
}
